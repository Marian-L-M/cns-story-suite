{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ES2020",
		"moduleResolution": "bundler",
		"jsx": "react",
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"baseUrl": ".",
		"paths": {
			"@wordpress/*": ["node_modules/@wordpress/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "build"]
}
